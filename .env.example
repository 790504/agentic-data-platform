# Copy to .env and fill in to enable LLM-powered planning & SQL self-repair.
# Without a key, the platform runs fully offline using the deterministic planner
# (graceful degradation) — every demo, test and eval still passes.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# ADP_MODEL=claude-sonnet-4-6
# ADP_DB_PATH=data/warehouse.duckdb
# ADP_MAX_RETRIES=3
# ADP_LOG_LEVEL=INFO

# --- Cloud warehouse (MotherDuck: serverless, DuckDB-compatible, free tier) ---
# Set backend to motherduck and provide a token to run on the cloud instead of a
# local file. Get a free token at https://app.motherduck.com (Settings -> Tokens).
# ADP_WAREHOUSE_BACKEND=motherduck
# ADP_MOTHERDUCK_DATABASE=adp
# MOTHERDUCK_TOKEN=your_token_here          # read directly by the duckdb motherduck extension

# --- dbt transform target ---
# dev (local DuckDB) | cloud (MotherDuck) | gcp (BigQuery). Auto-selected per backend.
# ADP_DBT_TARGET=dev

# --- BigQuery (GCP) target for dbt (run the same models on GCP) ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT=your-project
# BQ_DATASET=adp
